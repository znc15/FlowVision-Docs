    "sass-embedded": "^1.98.0",
    "typescript": "^6.0.2",
    "vue": "^3.5.31",
    "vuepress": "2.0.0-rc.27",
    "vuepress-theme-hope": "2.0.0-rc.105"
  },
  "pnpm": {
