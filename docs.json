{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "FlowVision 文档",
  "colors": {
    "primary": "#0050cb",
    "light": "#3B82F6",
    "dark": "#003A99"
  },
  "favicon": "/logo/logo_128.png",
  "navigation": {
    "tabs": [
      {
        "tab": "文档",
        "groups": [
          {
            "group": "开始",
            "pages": [
              "introduction",
              "quickstart",
              "configuration"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "功能指南",
        "groups": [
          {
            "group": "功能指南",
            "pages": [
              "features/ai-generate",
              "features/project-analysis",
              "features/visual-editor",
              "features/slash-commands",
              "features/prompt-generate",
              "features/keyboard-shortcuts",
              "features/export-import"
            ]
          }
        ]
      },
      {
        "tab": "MCP 集成",
        "groups": [
          {
            "group": "MCP 集成",
            "pages": ["mcp/overview", "mcp/tools-reference", "mcp/client-setup"]
          }
        ]
      },
      {
        "tab": "API 参考",
        "groups": [
          {
            "group": "REST & WebSocket",
            "pages": ["api/rest", "api/websocket"]
          },
          {
            "group": "接口示例",
            "pages": [
              "api-reference/introduction",
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      },
      {
        "tab": "架构设计",
        "groups": [
          {
            "group": "架构设计",
            "pages": [
              "architecture/overview",
              "architecture/frontend",
              "architecture/backend",
              "architecture/desktop"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://mintlify.com/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/logo_256.png",
    "dark": "/logo/logo_256.png"
  },
  "navbar": {
    "links": [
      {
        "label": "官网",
        "href": "https://znc15.github.io/FlowVision"
      },
      {
        "label": "GitHub",
        "href": "https://github.com/znc15/FlowVision"
      }
    ],
    "primary": {
      "type": "button",
      "label": "下载",
      "href": "https://github.com/znc15/FlowVision/releases/latest"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/znc15/FlowVision"
    }
  }
}
